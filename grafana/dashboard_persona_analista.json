      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-athena-datasource",
            "uid": "${DS_ATHENA}"
          },
          "connectionArgs": {
            "catalog": "__default",
            "database": "${ATHENA_DB}",
            "region": "__default"
          },
          "format": 1,
          "refId": "A",
          "rawSQL": "SELECT COALESCE(NULLIF(TRIM(uf), ''), '(sem UF)') AS uf,\n       CAST(SUM(CASE WHEN LOWER(TRIM(CAST(ceis_sancionado AS VARCHAR))) = 'true' THEN 1 ELSE 0 END) AS BIGINT) AS ceis_sim,\n       CAST(SUM(CASE WHEN LOWER(TRIM(CAST(ceis_sancionado AS VARCHAR))) <> 'true' OR ceis_sancionado IS NULL THEN 1 ELSE 0 END) AS BIGINT) AS ceis_nao\nFROM final_output\nGROUP BY 1\nORDER BY (ceis_sim + ceis_nao) DESC\nLIMIT 15"
        }
      ],
      "title": "CEIS por Capital",
      "type": "barchart"
    },
