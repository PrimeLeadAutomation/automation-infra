      "id": 10,
      "options": {
        "barRadius": 0,
        "barWidth": 0.85,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "xField": "cnae",
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 80
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana-athena-datasource",
            "uid": "${DS_ATHENA}"
          },
          "connectionArgs": {
            "catalog": "__default",
            "database": "${ATHENA_DB}",
            "region": "__default"
          },
          "format": 1,
          "refId": "A",
          "rawSQL": "WITH raw AS (\n  SELECT status, cnae_fiscal,\n    COALESCE(\n      TRY_CAST(TRIM(CAST(data_inicio_atividade AS VARCHAR)) AS DATE),\n      try(date_parse(nullif(TRIM(CAST(data_inicio_atividade AS VARCHAR)), ''), '%Y-%m-%d')),\n      try(date_parse(nullif(TRIM(CAST(data_inicio_atividade AS VARCHAR)), ''), '%d/%m/%Y'))\n    ) AS di\n  FROM final_output\n),\nbase AS (\n  SELECT substr(regexp_replace(CAST(cnae_fiscal AS VARCHAR), '[^0-9]', ''), 1, 7) AS cnae,\n         CASE WHEN di <= current_date - INTERVAL '5' YEAR THEN 1 ELSE 0 END AS madura\n  FROM raw\n  WHERE UPPER(TRIM(status)) = 'ATIVA' AND cnae_fiscal IS NOT NULL\n)\nSELECT cnae,\n       100.0 * CAST(SUM(madura) AS DOUBLE) / NULLIF(COUNT(*), 0) AS pct_maduras\nFROM base\nWHERE LENGTH(cnae) >= 4\nGROUP BY cnae\nHAVING COUNT(*) >= 1\nORDER BY COUNT(*) DESC\nLIMIT 12"
        }
      ],
      "title": "Empresas ativas maduras por CNAE (%)",
      "type": "barchart"
    },
