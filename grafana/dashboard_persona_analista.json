          "format": 1,
          "refId": "A",
          "rawSQL": "SELECT cnpj_formatado, razao_social, uf, municipio, status,\n       ceis_sancionado, cnep_sancionado, substr(COALESCE(CAST(ceis_detalhes AS VARCHAR), ''), 1, 120) AS ceis_resumo,\n       substr(COALESCE(CAST(cnep_detalhes AS VARCHAR), ''), 1, 120) AS cnep_resumo\nFROM final_output\nWHERE (LOWER(TRIM(CAST(ceis_sancionado AS VARCHAR))) = 'true') OR (LOWER(TRIM(CAST(cnep_sancionado AS VARCHAR))) = 'true')\nORDER BY uf, razao_social\nLIMIT 500"
